# Frontend (Vercel) — API backend URL. Leave empty if vercel.json proxies /api to Render.
# VITE_API_BASE=https://kapsul.onrender.com

# Mistral API — required for AI Chat (upload + chat)
# Copy to .env.local in project root (same folder as server.py)
MISTRAL_API_KEY=your_mistral_api_key_here
# Optional: HTTP read timeout for Mistral (ms). Default 600000 (10 min).
# MISTRAL_TIMEOUT_MS=600000
# Optional: model for document synthesis. Default mistral-small-latest (faster).
# MISTRAL_SYNTHESIS_MODEL=mistral-small-latest
# Optional: max extracted chars sent to Mistral per upload. Default 60000.
# MAX_UPLOAD_CHARS=60000

# Supabase — required for library uploads + session persistence (Render backend, NOT Vercel)
# Use the SERVICE ROLE key only — do NOT use the anon key on the backend.
# Supabase → Project Settings → API → service_role (secret)
# Render Dashboard → kapsul-api → Environment → add both variables, then redeploy.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

