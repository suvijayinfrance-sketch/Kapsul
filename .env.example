# Mistral API — required for AI Chat (upload + chat)
# Copy to .env.local in project root (same folder as server.py)
MISTRAL_API_KEY=your_mistral_api_key_here
# Optional: HTTP read timeout for Mistral (ms). Default 600000 (10 min).
# MISTRAL_TIMEOUT_MS=600000
# Optional: model for document synthesis. Default mistral-small-latest (faster).
# MISTRAL_SYNTHESIS_MODEL=mistral-small-latest
# Optional: max extracted chars sent to Mistral per upload. Default 60000.
# MAX_UPLOAD_CHARS=60000

# Supabase — required for session persistence (server.py / db.py)
# Use service role key on the backend only (never expose in frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Optional: for future client-side Supabase usage
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

